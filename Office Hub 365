// ==========================================
// 4. POWERPOINT SLIDES EDITOR
// ==========================================
function PowerPointEditor({ 
  doc, 
  onBack, 
  onUpdate, 
  onRename,
  isCopilotOpen,
  setIsCopilotOpen,
  aiPrompt,
  setAiPrompt,
  aiLoading,
  setAiLoading,
  triggerNotification,
  onPresent
}) {
  const [activeSlideIndex, setActiveSlideIndex] = useState(0);

  const slides = doc.content.slides || [];

  const handleUpdateSlideField = (field, value) => {
    const updatedSlides = [...slides];
    updatedSlides[activeSlideIndex] = {
      ...updatedSlides[activeSlideIndex],
      [field]: value
    };
    onUpdate({
      ...doc.content,
      slides: updatedSlides
    });
  };

  const handleUpdateBulletPoint = (bIdx, value) => {
    const updatedSlides = [...slides];
    const updatedBullets = [...updatedSlides[activeSlideIndex].bullets];
    updatedBullets[bIdx] = value;
    updatedSlides[activeSlideIndex] = {
      ...updatedSlides[activeSlideIndex],
      bullets: updatedBullets
    };
    onUpdate({
      ...doc.content,
      slides: updatedSlides
    });
  };

  const handleAddBulletPoint = () => {
    const updatedSlides = [...slides];
    const updatedBullets = [...(updatedSlides[activeSlideIndex].bullets || []), "New slide bullet item"];
    updatedSlides[activeSlideIndex] = {
      ...updatedSlides[activeSlideIndex],
      bullets: updatedBullets
    };
    onUpdate({
      ...doc.content,
      slides: updatedSlides
    });
  };

  const handleRemoveBulletPoint = (bIdx) => {
    const updatedSlides = [...slides];
    const updatedBullets = (updatedSlides[activeSlideIndex].bullets || []).filter((_, idx) => idx !== bIdx);
    updatedSlides[activeSlideIndex] = {
      ...updatedSlides[activeSlideIndex],
      bullets: updatedBullets
    };
    onUpdate({
      ...doc.content,
      slides: updatedSlides
    });
  };

  const handleAddNewSlide = () => {
    const newSlide = {
      id: `s-${Date.now()}`,
      title: 'New Slide Title',
      subtitle: 'New slide subtitle description details',
      bullets: ['Highlight bullet point number one'],
      bgClass: 'from-blue-600 to-indigo-800'
    };
    onUpdate({
      ...doc.content,
      slides: [...slides, newSlide]
    });
    setActiveSlideIndex(slides.length);
    triggerNotification("Added new slide");
  };

  const handleDeleteSlide = (idx, e) => {
    if (e) e.stopPropagation();
    if (slides.length <= 1) {
      triggerNotification("You need to keep at least 1 slide!", "warning");
      return;
    }
    const updated = slides.filter((_, sIdx) => sIdx !== idx);
    onUpdate({
      ...doc.content,
      slides: updated
    });
    setActiveSlideIndex(Math.max(0, idx - 1));
    triggerNotification("Slide removed");
  };

  const changeSlideBg = (bgClass) => {
    handleUpdateSlideField('bgClass', bgClass);
  };

  const executeCopilotPowerpoint = async () => {
    if (!aiPrompt.trim()) return;
    setAiLoading(true);
    try {
      const systemPrompt = "You are an expert Presentation designer. Output response as a valid JSON with schema structure: { \"slides\": [ { \"title\": \"...\", \"subtitle\": \"...\", \"bullets\": [\"...\", \"...\"], \"bgClass\": \"from-slate-800 to-slate-900\" } ] }";
      
      const responseText = await callGemini(
        `Generate 3 coherent PowerPoint slides outline on the topic: "${aiPrompt}". Choose color scheme bgClass from standard Tailwind configurations (e.g. from-indigo-700 to-purple-800, from-rose-600 to-orange-500, from-teal-600 to-emerald-700). Respond ONLY with valid raw JSON.`,
        systemPrompt,
        true // JSON parsing mode
      );

      const parsed = JSON.parse(responseText);
      if (parsed && Array.isArray(parsed.slides)) {
        onUpdate({
          ...doc.content,
          slides: [...slides, ...parsed.slides]
        });
        setActiveSlideIndex(slides.length);
        triggerNotification("PowerPoint Slides Drafted with AI!");
        setAiPrompt('');
      } else {
        throw new Error("Invalid structure returned");
      }
    } catch (err) {
      console.error(err);
      triggerNotification("Could not parse AI PowerPoint output", "error");
    } finally {
      setAiLoading(false);
    }
  };

  const activeSlide = slides[activeSlideIndex] || slides[0];

  return (
    <div className="flex-1 flex flex-col md:flex-row h-screen overflow-hidden">
      {/* PPT Sidebar & Slide Sorter */}
      <div className="w-full md:w-60 border-b md:border-b-0 md:border-r border-slate-200 bg-white flex flex-col shrink-0">
        <div className="p-4 border-b border-slate-200 flex items-center justify-between">
          <span className="font-bold text-xs text-slate-500 uppercase tracking-wider">Slide Sorter</span>
          <button 
            onClick={handleAddNewSlide}
            className="p-1 hover:bg-slate-100 rounded-lg text-orange-600 flex items-center gap-1 text-xs font-semibold"
          >
            <PlusCircle className="w-4 h-4" /> Slide
          </button>
        </div>

        <div className="flex-1 overflow-y-auto p-4 flex md:flex-col gap-3">
          {slides.map((s, idx) => (
            <div 
              key={s.id || idx}
              onClick={() => setActiveSlideIndex(idx)}
              className={`p-3 rounded-xl border text-left cursor-pointer transition-all shrink-0 w-36 md:w-full ${activeSlideIndex === idx ? 'border-orange-500 bg-orange-50/50 shadow-sm' : 'border-slate-200 bg-white hover:border-slate-300'}`}
            >
              <div className={`h-16 w-full rounded-md bg-gradient-to-tr ${s.bgClass || 'from-indigo-600 to-purple-800'} mb-2 p-1.5 overflow-hidden flex flex-col justify-between text-white`}>
                <span className="text-[8px] font-bold truncate">{s.title}</span>
                <span className="text-[6px] truncate opacity-80">{s.subtitle}</span>
              </div>
              <div className="flex items-center justify-between text-[10px] text-slate-500 font-bold">
                <span>Slide {idx + 1}</span>
                <button 
                  onClick={(e) => handleDeleteSlide(idx, e)}
                  className="p-1 hover:text-rose-600 hover:bg-rose-50 rounded"
                >
                  <Trash2 className="w-3 h-3" />
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Editor Main Space */}
      <div className="flex-1 flex flex-col min-w-0 bg-slate-100 overflow-y-auto">
        {/* Editor Top Control Bar */}
        <div className="bg-white border-b border-slate-200 px-4 py-3 flex items-center justify-between sticky top-0 z-20">
          <div className="flex items-center gap-3 min-w-0">
            <button onClick={onBack} className="p-1.5 hover:bg-slate-100 rounded-lg text-slate-500">
              <ChevronLeft className="w-5 h-5" />
            </button>
            <div className="p-1.5 bg-orange-100 text-orange-600 rounded-lg">
              <Presentation className="w-5 h-5" />
            </div>
            <input 
              type="text" 
              value={doc.title}
              onChange={(e) => onRename(e.target.value)}
              className="font-semibold text-slate-800 text-sm md:text-base focus:outline-none focus:border-indigo-500 border border-transparent rounded px-1 w-40 md:w-64"
            />
          </div>

          <div className="flex items-center gap-2">
            <button 
              onClick={onPresent}
              className="flex items-center gap-1.5 bg-slate-800 hover:bg-slate-900 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors shadow-xs"
            >
              <Play className="w-3.5 h-3.5 fill-current" />
              <span>Present</span>
            </button>

            <button 
              onClick={() => setIsCopilotOpen(!isCopilotOpen)}
              className="flex items-center gap-1 bg-orange-50 hover:bg-orange-100 text-orange-700 px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors"
            >
              <Sparkles className="w-3.5 h-3.5" />
              <span>Copilot</span>
            </button>
          </div>
        </div>

        {/* Dynamic Canvas Area */}
        <div className="flex-1 p-6 md:p-12 flex flex-col items-center justify-center">
          
          {/* Theme background picker */}
          <div className="bg-white border border-slate-200 px-4 py-2 rounded-2xl flex items-center gap-2 mb-4 shadow-xs">
            <span className="text-xs font-bold text-slate-400 uppercase tracking-wide mr-2">Slide Theme:</span>
            <button onClick={() => changeSlideBg('from-rose-500 to-orange-500')} className="w-6 h-6 rounded-full bg-gradient-to-tr from-rose-500 to-orange-500 border border-white hover:scale-110 transition-transform shadow-xs" title="Warm Sunset"></button>
            <button onClick={() => changeSlideBg('from-blue-600 to-indigo-800')} className="w-6 h-6 rounded-full bg-gradient-to-tr from-blue-600 to-indigo-800 border border-white hover:scale-110 transition-transform shadow-xs" title="Corporate Indigo"></button>
            <button onClick={() => changeSlideBg('from-emerald-500 to-teal-700')} className="w-6 h-6 rounded-full bg-gradient-to-tr from-emerald-500 to-teal-700 border border-white hover:scale-110 transition-transform shadow-xs" title="Oceanic Teal"></button>
            <button onClick={() => changeSlideBg('from-slate-800 to-slate-950')} className="w-6 h-6 rounded-full bg-gradient-to-tr from-slate-800 to-slate-950 border border-white hover:scale-110 transition-transform shadow-xs" title="Sleek Obsidian"></button>
          </div>

          {activeSlide ? (
            <div className={`w-full max-w-3xl aspect-[16/9] bg-gradient-to-tr ${activeSlide.bgClass || 'from-indigo-600 to-purple-800'} text-white p-8 md:p-12 rounded-2xl shadow-xl flex flex-col justify-between transition-all relative`}>
              
              <div>
                <input 
                  type="text"
                  value={activeSlide.title || ''}
                  onChange={(e) => handleUpdateSlideField('title', e.target.value)}
                  className="bg-transparent text-2xl md:text-4xl font-extrabold focus:outline-none focus:border-white/40 border-b border-transparent w-full text-white placeholder-white/50 pb-1 mb-2"
                  placeholder="Click to set slide title"
                />
                
                <input 
                  type="text"
                  value={activeSlide.subtitle || ''}
                  onChange={(e) => handleUpdateSlideField('subtitle', e.target.value)}
                  className="bg-transparent text-sm md:text-base font-semibold text-orange-200 focus:outline-none focus:border-white/40 border-b border-transparent w-full placeholder-orange-200/50 pb-1 mb-6"
                  placeholder="Click to set slide subtitle description"
                />

                <div className="flex flex-col gap-2 mt-4">
                  {(activeSlide.bullets || []).map((bullet, bIdx) => (
                    <div key={bIdx} className="flex items-center gap-2 group/bullet">
                      <span className="text-orange-300">•</span>
                      <input 
                        type="text"
                        value={bullet}
                        onChange={(e) => handleUpdateBulletPoint(bIdx, e.target.value)}
                        className="bg-transparent text-xs md:text-sm text-white/90 focus:outline-none border-b border-transparent focus:border-white/20 flex-1"
                      />
                      <button 
                        onClick={() => handleRemoveBulletPoint(bIdx)}
                        className="opacity-0 group-hover/bullet:opacity-100 p-1 text-white/50 hover:text-rose-400 transition-opacity"
                      >
                        <MinusCircle className="w-3.5 h-3.5" />
                      </button>
                    </div>
                  ))}
                  
                  <button 
                    onClick={handleAddBulletPoint}
                    className="flex items-center gap-1.5 text-xs text-white/60 hover:text-white mt-2 font-semibold"
                  >
                    <Plus className="w-3.5 h-3.5" /> Add bullet item
                  </button>
                </div>
              </div>

              <div className="text-[10px] text-white/40 font-bold tracking-widest flex justify-between uppercase">
                <span>Office 365 Hub Presentations</span>
                <span>Slide {activeSlideIndex + 1} of {slides.length}</span>
              </div>
            </div>
          ) : (
            <div className="text-center text-slate-500">
              <p className="text-sm font-semibold">No Slide Selected</p>
            </div>
          )}
        </div>
      </div>

      {/* AI Copilot Side Panel */}
      {isCopilotOpen && (
        <div className="w-full md:w-80 border-t md:border-t-0 md:border-l border-slate-200 bg-white flex flex-col h-[350px] md:h-full shrink-0">
          <div className="px-4 py-3 bg-orange-50 border-b border-orange-100 flex items-center justify-between">
            <div className="flex items-center gap-2 text-orange-800">
              <Sparkles className="w-4 h-4 animate-spin text-orange-600" />
              <span className="font-bold text-sm">PowerPoint Copilot</span>
            </div>
            <button 
              onClick={() => setIsCopilotOpen(false)}
              className="p-1 hover:bg-orange-100 rounded text-orange-600"
            >
              <X className="w-4 h-4" />
            </button>
          </div>

          <div className="flex-1 overflow-y-auto p-4 flex flex-col gap-3">
            <div className="p-3 bg-slate-50 rounded-xl border border-slate-100 text-xs text-slate-600">
              💡 Create fully structured slides in seconds with Gemini! Try: <br />
              <span className="italic">"Outline slides for a pitch deck explaining our revolutionary electric car sharing startup model."</span>
            </div>

            <textarea 
              rows={4}
              placeholder="Tell PowerPoint what presentation slides to create..."
              value={aiPrompt}
              onChange={(e) => setAiPrompt(e.target.value)}
              className="w-full border border-slate-200 rounded-xl p-3 text-xs focus:outline-none focus:ring-2 focus:ring-orange-500 resize-none bg-slate-50"
            />

            <button 
              onClick={executeCopilotPowerpoint}
              disabled={aiLoading}
              className="w-full bg-gradient-to-r from-orange-600 to-rose-600 text-white font-semibold py-2.5 rounded-xl hover:opacity-90 active:scale-98 transition-all text-xs flex items-center justify-center gap-2"
            >
              {aiLoading ? (
                <>
                  <RefreshCw className="w-4 h-4 animate-spin" />
                  <span>Drafting Slide Outline...</span>
                </>
              ) : (
                <>
                  <Sparkles className="w-4 h-4" />
                  <span>Generate Slides</span>
                </>
              )}
            </button>
          </div>
        </div>
      )}
    </div>
  );
}


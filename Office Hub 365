// 5. POWERPOINT PRESENTATION SLIDESHOW VIEWER
// ==========================================
function PresentationViewer({ doc, onClose }) {
  const [slideIdx, setSlideIdx] = useState(0);
  const slides = doc.content.slides || [];
  const currentSlide = slides[slideIdx];

  const handleNext = () => {
    if (slideIdx < slides.length - 1) {
      setSlideIdx(slideIdx + 1);
    }
  };

  const handlePrev = () => {
    if (slideIdx > 0) {
      setSlideIdx(slideIdx - 1);
    }
  };

  if (!currentSlide) return null;

  return (
    <div className="fixed inset-0 z-50 bg-slate-950 flex flex-col justify-between text-white p-8 md:p-16 select-none animate-fade-in">
      
      {/* Top Header Controls */}
      <div className="flex items-center justify-between border-b border-white/10 pb-4">
        <div>
          <h2 className="text-sm font-bold opacity-60 uppercase tracking-widest">{doc.title}</h2>
          <span className="text-xs opacity-45">Slideshow Presentation Mode</span>
        </div>
        <button 
          onClick={onClose}
          className="bg-white/15 hover:bg-white/20 text-white font-semibold px-4 py-1.5 rounded-lg text-xs transition-colors"
        >
          Exit Slideshow
        </button>
      </div>

      {/* Slide Body */}
      <div className={`my-auto bg-gradient-to-tr ${currentSlide.bgClass || 'from-indigo-600 to-purple-800'} p-12 md:p-24 rounded-3xl shadow-2xl flex flex-col justify-between aspect-[16/9] max-w-5xl mx-auto w-full border border-white/5`}>
        <div>
          <h1 className="text-3xl md:text-5xl font-black mb-3">{currentSlide.title}</h1>
          <p className="text-md md:text-xl text-orange-200 font-semibold mb-8">{currentSlide.subtitle}</p>

          <div className="flex flex-col gap-3">
            {(currentSlide.bullets || []).map((bullet, bIdx) => (
              <div key={bIdx} className="flex items-start gap-3">
                <span className="text-orange-300 text-lg">•</span>
                <p className="text-sm md:text-lg text-white/90">{bullet}</p>
              </div>
            ))}
          </div>
        </div>

        <div className="text-xs text-white/40 flex justify-between font-bold uppercase tracking-wider mt-12">
          <span>{doc.title}</span>
          <span>Slide {slideIdx + 1} of {slides.length}</span>
        </div>
      </div>

      {/* Slide Navigation Controls */}
      <div className="flex justify-between items-center max-w-xs mx-auto w-full pt-4 border-t border-white/10">
        <button 
          onClick={handlePrev}
          disabled={slideIdx === 0}
          className="p-3 bg-white/10 hover:bg-white/15 disabled:opacity-30 rounded-full text-white transition-opacity"
        >
          <ChevronLeft className="w-5 h-5" />
        </button>

        <span className="text-xs font-semibold opacity-70">
          Slide {slideIdx + 1} / {slides.length}
        </span>

        <button 
          onClick={handleNext}
          disabled={slideIdx === slides.length - 1}
          className="p-3 bg-white/10 hover:bg-white/15 disabled:opacity-30 rounded-full text-white transition-opacity"
        >
          <ChevronRight className="w-5 h-5" />
        </button>
      </div>

    </div>
  );
}


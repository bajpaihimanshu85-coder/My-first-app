  aiPrompt,
  setAiPrompt,
  aiLoading,
  setAiLoading,
  triggerNotification
}) {
  const editorRef = useRef(null);

  // Sync content with ref
  useEffect(() => {
    if (editorRef.current && editorRef.current.innerHTML !== doc.content) {
      editorRef.current.innerHTML = doc.content;
    }
  }, [doc.id]);

  const handleTextFormat = (command, value = null) => {
    document.execCommand(command, false, value);
    if (editorRef.current) {
      onUpdate(editorRef.current.innerHTML);
    }
  };

  const handleContentInput = () => {
    if (editorRef.current) {
      onUpdate(editorRef.current.innerHTML);
    }
  };

  const executeCopilotDraft = async () => {
    if (!aiPrompt.trim()) return;
    setAiLoading(true);
    try {
      const result = await callGemini(
        `Draft professional document body text or outline regarding: "${aiPrompt}". Keep it comprehensive and format using clean, simple HTML paragraphs or heading structures.`,

            >
              <X className="w-4 h-4" />
            </button>
          </div>

          <div className="flex-1 overflow-y-auto p-4 flex flex-col gap-3">
            <div className="p-3 bg-slate-50 rounded-xl border border-slate-100 text-xs text-slate-600">
              💡 Draft rich spreadsheet models with Gemini! Try: <br />
              <span className="italic">"Generate an inventory spreadsheet of technology hardware products with categories, quantities, pricing."</span>
            </div>

            <textarea 
              rows={4}
              placeholder="Draft table prompt..."

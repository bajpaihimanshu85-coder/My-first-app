function ExcelEditor({ 
  doc, 
  onBack, 
  onUpdate, 
  onRename,
  isCopilotOpen,
  setIsCopilotOpen,
  aiPrompt,
  setAiPrompt,
  aiLoading,
  setAiLoading,
  triggerNotification
}) {
  const [activeCell, setActiveCell] = useState({ r: 0, c: 0 });
  const [formulaInput, setFormulaInput] = useState('');

  // Handle excel grid values
  const grid = doc.content.grid;
  const cellStyles = doc.content.styles || {};

  // Simple Formula Evaluator
  const evaluateGridValue = (val, currentGrid) => {
    if (!val || typeof val !== 'string' || !val.startsWith('=')) {
      return val;
    }

    try {
      const formula = val.slice(1).toUpperCase(); // e.g. SUM(B2:D2)
      const sumMatch = formula.match(/^SUM\(([A-Z])([0-9]+):([A-Z])([0-9]+)\)$/);
      const avgMatch = formula.match(/^AVERAGE\(([A-Z])([0-9]+):([A-Z])([0-9]+)\)$/);

      const cellToIndex = (colLetter, rowStr) => {
        const c = colLetter.charCodeAt(0) - 65; // A=0, B=1
        const r = parseInt(rowStr) - 1; // 1-based to 0-based index
        return { r, c };
      };

      if (sumMatch) {
        const start = cellToIndex(sumMatch[1], sumMatch[2]);
        const end = cellToIndex(sumMatch[3], sumMatch[4]);
        let total = 0;
        for (let r = start.r; r <= end.r; r++) {
          for (let c = start.c; c <= end.c; c++) {
            const cellVal = parseFloat(currentGrid[r]?.[c] || 0);
            if (!isNaN(cellVal)) total += cellVal;
          }
        }
        return total;
      }

      if (avgMatch) {
        const start = cellToIndex(avgMatch[1], avgMatch[2]);
        const end = cellToIndex(avgMatch[3], avgMatch[4]);
        let total = 0;
        let count = 0;
        for (let r = start.r; r <= end.r; r++) {
          for (let c = start.c; c <= end.c; c++) {
            const cellVal = parseFloat(currentGrid[r]?.[c] || 0);
            if (!isNaN(cellVal)) {
              total += cellVal;
              count++;
            }
          }
        }
        return count > 0 ? (total / count).toFixed(2) : 0;
      }

      // Basic simple evaluation fallback
      return "Calc Error";
    } catch (e) {
      return "Formula Error";
    }
  };

  const updateCell = (r, c, value) => {
    const updatedGrid = [...grid];
    updatedGrid[r][c] = value;
    onUpdate({
      ...doc.content,
      grid: updatedGrid
    });
  };

  const handleCellSelect = (r, c) => {
    setActiveCell({ r, c });
    setFormulaInput(grid[r]?.[c] || '');
  };

  const applyFormulaToActive = () => {
    updateCell(activeCell.r, activeCell.c, formulaInput);
  };

  const getColLetter = (index) => String.fromCharCode(65 + index);

  const applyFormatting = (styleName, val) => {
    const coord = `${getColLetter(activeCell.c)}${activeCell.r + 1}`;
    const newStyles = { ...cellStyles };
    if (!newStyles[coord]) newStyles[coord] = {};
    newStyles[coord][styleName] = val;
    onUpdate({
      ...doc.content,
      styles: newStyles
    });
  };

  const executeCopilotGrid = async () => {
    if (!aiPrompt.trim()) return;
    setAiLoading(true);
    try {
      const result = await callGemini(
        `Draft dynamic spreadsheet table contents regarding: "${aiPrompt}". Return raw CSV styled format starting with Column headers on the first line and exactly 6-10 subsequent rows. Example:
Product,Price,Quantity
Apples,1.2,5
Oranges,1.5,10`,
        "You are an expert AI Spreadsheet architect."
      );
      
      const rows = result.split('\n').filter(r => r.trim());
      const tempGrid = [...grid];

      rows.forEach((row, rIdx) => {
        if (rIdx < tempGrid.length) {
          const cells = row.split(',').map(c => c.trim().replace(/['"]+/g, ''));
          cells.forEach((cVal, cIdx) => {
            if (cIdx < tempGrid[0].length) {
              tempGrid[rIdx][cIdx] = cVal;
            }
          });
        }
      });

      onUpdate({
        ...doc.content,
        grid: tempGrid
      });
      triggerNotification("AI Spreadsheet Table Created!");
      setAiPrompt('');
    } catch (err) {
      console.error(err);
      triggerNotification("Failed to generate table with Gemini", "error");
    } finally {
      setAiLoading(false);
    }
  };

  const handleDownloadCSV = () => {
    const csvContent = grid.map(r => r.join(',')).join('\n');
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `${doc.title}.csv`;
    link.click();
    triggerNotification("Downloaded CSV Copy");
  };

  return (
    <div className="flex-1 flex flex-col md:flex-row h-screen overflow-hidden">
      {/* Excel Sheet Space */}
      <div className="flex-1 flex flex-col min-w-0 bg-slate-50 overflow-y-auto">
        
        {/* Editor Top Control Bar */}
        <div className="bg-white border-b border-slate-200 px-4 py-3 flex items-center justify-between sticky top-0 z-20">
          <div className="flex items-center gap-3 min-w-0">
            <button onClick={onBack} className="p-1.5 hover:bg-slate-100 rounded-lg text-slate-500">
              <ChevronLeft className="w-5 h-5" />
            </button>
            <div className="p-1.5 bg-emerald-100 text-emerald-600 rounded-lg">
              <FileSpreadsheet className="w-5 h-5" />
            </div>
            <input 
              type="text" 
              value={doc.title}
              onChange={(e) => onRename(e.target.value)}
              className="font-semibold text-slate-800 text-sm md:text-base focus:outline-none focus:border-indigo-500 border border-transparent rounded px-1 w-40 md:w-64"
            />
          </div>

          <div className="flex items-center gap-2">
            <button 
              onClick={() => setIsCopilotOpen(!isCopilotOpen)}
              className="flex items-center gap-1 bg-emerald-50 hover:bg-emerald-100 text-emerald-700 px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors"
            >
              <Sparkles className="w-3.5 h-3.5" />
              <span>Copilot</span>
            </button>

            <button 
              onClick={handleDownloadCSV}
              title="Download as CSV"
              className="p-1.5 text-slate-500 hover:bg-slate-100 rounded-lg transition-colors"
            >
              <FileDown className="w-5 h-5" />
            </button>
          </div>
        </div>

        {/* Formula Bar */}
        <div className="bg-slate-100 border-b border-slate-200 px-4 py-2 flex items-center gap-2">
          <div className="flex items-center gap-1.5 bg-white border border-slate-200 px-2 py-1 rounded-lg text-xs text-slate-500 font-bold uppercase select-none shadow-xs">
            <span>Cell {getColLetter(activeCell.c)}{activeCell.r + 1}</span>
          </div>
          <span className="text-xs font-bold text-slate-500">fx</span>
          <div className="flex-1 flex gap-2">
            <input 
              type="text"
              placeholder="e.g. =SUM(B2:D2) or simple value"
              value={formulaInput}
              onChange={(e) => setFormulaInput(e.target.value)}
              onKeyDown={(e) => {
                if (e.key === 'Enter') applyFormulaToActive();
              }}
              className="flex-1 bg-white border border-slate-200 rounded-lg px-3 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-emerald-500 font-mono"
            />
            <button 
              onClick={applyFormulaToActive}
              className="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-xs px-3 py-1 rounded-lg transition-colors"
            >
              Enter
            </button>
          </div>
        </div>

        {/* Excel Formatting Bar */}
        <div className="bg-slate-50 border-b border-slate-200 px-4 py-2 flex items-center gap-2 flex-wrap">
          <button 
            onClick={() => applyFormatting('bold', true)}
            className="p-1 hover:bg-slate-200 rounded text-slate-700 text-xs font-bold flex items-center gap-1"
          >
            <Bold className="w-3.5 h-3.5" /> Bold
          </button>
          <div className="w-px h-4 bg-slate-300"></div>
          <button 
            onClick={() => applyFormatting('bg', 'bg-yellow-100')}
            className="p-1 hover:bg-slate-200 rounded text-xs text-yellow-800 flex items-center gap-1 font-semibold"
          >
            🎨 Yellow Bg
          </button>
          <button 
            onClick={() => applyFormatting('bg', 'bg-emerald-100')}
            className="p-1 hover:bg-slate-200 rounded text-xs text-emerald-800 flex items-center gap-1 font-semibold"
          >
            🎨 Green Bg
          </button>
          <button 
            onClick={() => applyFormatting('bg', '')}
            className="p-1 hover:bg-slate-200 rounded text-xs text-slate-500 flex items-center gap-1 font-semibold"
          >
            Reset Style
          </button>
        </div>

        {/* Spreadsheet Cells Grid */}
        <div className="flex-1 overflow-auto p-4 bg-slate-100">
          <div className="inline-block bg-white border border-slate-200 rounded-xl overflow-hidden shadow-xs">
            <table className="border-collapse text-left text-xs text-slate-600">
              <thead>
                <tr className="bg-slate-50 border-b border-slate-200">
                  <th className="px-3 py-2 border-r border-slate-200 text-center select-none bg-slate-100 font-bold w-12 text-[10px] text-slate-400">#</th>
                  {grid[0]?.map((_, colIdx) => (
                    <th 
                      key={colIdx} 
                      className="px-4 py-2 border-r border-slate-200 text-center select-none font-bold bg-slate-100 text-slate-500"
                      style={{ minWidth: '110px' }}
                    >
                      {getColLetter(colIdx)}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {grid.map((row, rIdx) => (
                  <tr key={rIdx} className="border-b border-slate-100 hover:bg-slate-50/50">
                    <td className="px-3 py-1.5 border-r border-slate-200 text-center select-none bg-slate-50 font-semibold text-slate-400 text-[10px]">
                      {rIdx + 1}
                    </td>
                    {row.map((cellVal, cIdx) => {
                      const coord = `${getColLetter(cIdx)}${rIdx + 1}`;
                      const style = cellStyles[coord] || {};
                      const isSelected = activeCell.r === rIdx && activeCell.c === cIdx;

                      // Evaluate formulas in cells (display evaluation, keep raw in memory)
                      const evaluated = evaluateGridValue(cellVal, grid);

                      return (
                        <td 
                          key={cIdx}
                          onClick={() => handleCellSelect(rIdx, cIdx)}
                          className={`border-r border-slate-200 relative p-0 group cursor-pointer transition-colors ${style.bg || ''} ${isSelected ? 'ring-2 ring-emerald-500 ring-inset bg-emerald-50/25 z-10' : ''}`}
                        >
                          <input 
                            type="text" 
                            value={isSelected ? formulaInput : (evaluated || '')}
                            onChange={(e) => {
                              if (isSelected) {
                                setFormulaInput(e.target.value);
                              } else {
                                updateCell(rIdx, cIdx, e.target.value);
                              }
                            }}
                            onBlur={() => {
                              if (isSelected) applyFormulaToActive();
                            }}
                            className={`w-full h-full px-3 py-2 bg-transparent focus:outline-none font-mono ${style.bold ? 'font-bold' : ''} ${style.color || 'text-slate-800'}`}
                          />
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      {/* AI Copilot Side Panel */}
      {isCopilotOpen && (
        <div className="w-full md:w-80 border-t md:border-t-0 md:border-l border-slate-200 bg-white flex flex-col h-[350px] md:h-full shrink-0">
          <div className="px-4 py-3 bg-emerald-50 border-b border-emerald-100 flex items-center justify-between">
            <div className="flex items-center gap-2 text-emerald-800">
              <Sparkles className="w-4 h-4 animate-spin text-emerald-600" />
              <span className="font-bold text-sm">Excel Copilot</span>
            </div>
